header(class="bg-indigo-600 p-4  ")
    .container.mx-auto.flex.justify-between.items-center
        a(href="/")
            h1.text-2xl.text-white.font-extrabold.text-center Bienes 
                span.font-normal Raices
        
        if usuario
            nav(class="my-5 text-sm md:flex md:items-center md:gap-3 font-bold text-white hidden")
            
                a(href="/mis-propiedades") Mis Propiedades
                form(action="/auth/cerrar-sesion" method="POST")
                    input(type="hidden" name="_csrf" value=csrfToken)
                    input(type="submit" class="bg-indigo-800 py-2 px-10 rounded-lg" value="Cerrar Sesión")
        else
            nav(class="my-5 text-sm md:flex md:items-center md:gap-3 font-bold text-white hidden")
                a(href="/auth/registro") Craer Cuenta
                a(href="/auth/login") Iniciar Sesión

div(class="bg-indigo-700 py-5")
    div(class="container mx-auto flex flex-col gap-4 items-center lg:flex-row lg:justify-between")

        nav(class="flex flex-wrap gap-3 items-center justify-center lg:justify-start lg:flex-1")
            a(href="/categorias/1" class="text-sm font-bold uppercase text-white") Casas
            a(href="/categorias/2" class="text-sm font-bold uppercase text-white") Departamentos
            a(href="/categorias/3" class="text-sm font-bold uppercase text-white") Bodegas
            a(href="/categorias/4" class="text-sm font-bold uppercase text-white") Terrenos
            a(href="/categorias/5" class="text-sm font-bold uppercase text-white") Cabañas

        div(class="flex w-full lg:w-auto justify-center lg:justify-end")
            form(action="/buscador" method="POST" class="flex flex-col sm:flex-row gap-3 items-center w-full lg:w-auto")
                input(type="hidden" name="_csrf" value=csrfToken)
                label(for="termino" class="text-sm uppercase font-bold text-white") Búsqueda:
                input(type="text" id="termino" name="termino" placeholder="Buscar Propiedades" class="p-2 rounded-lg shadow text-sm w-full lg:w-64")

                input(type="submit" class="bg-indigo-800 hover:bg-indigo-400 rounded-lg text-white uppercase font-bold p-2 cursor-pointer text-sm w-full sm:w-auto" value="Buscar")