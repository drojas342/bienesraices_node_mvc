extends layout/app

block styles  
    link(rel="stylesheet" href="https://unpkg.com/leaflet@1.8.0/dist/leaflet.css")
    
block contenido 
    div(class="py-5 ")
        h1(class="text-center text-4xl font-extrabold") Ubicacion en el Mapa

        div(class="flex flex-col md:flex-row items-center py-10 gap-4")
            h2(vlass="text-sm uppercase text-gray-800 font-bold") Filtras Propiedades:

            div(class="w-full md:w-auto flex items-center gap-2")
                label(for="categorias" class="text-sm w-24 uppercase font-bold") Categorías
                select(id="categorias" class="flex-1 bg-white w-full px-3 py-2 border border-gray-300 rounded-md shadow")
                    option(value="" selected) - Seleccione -
                    each categoria in categorias
                        option(value=categoria.id) #{categoria.nombre}

            div(class="w-full md:w-auto flex items-center gap-2")
                label(for="precios" class="text-sm w-24 uppercase font-bold") Precios
                select(id="precios" class="flex-1 bg-white w-full px-3 py-2 border border-gray-300 rounded-md shadow")
                    option(value="" selected) - Seleccione -
                    each precio in precios
                        option(value=precio.id) #{precio.nombre}
                        
        div(id="mapa-inicio" class="h-[600px] mt-5 ")

        section(class="py-10")
            h2(class="text-center text-4xl pt-10 font-extrabold") Casas en Venta

            div(class="grid grid-cols-1 lg:grid-cols-3 gap-5 mt-14")
                each propiedad in casas
                    include ./template/card.pug
        
        section(class="py-10")
            h2(class="text-center text-4xl pt-10 font-extrabold") Departamentos en Venta

            div(class="grid grid-cols-1 lg:grid-cols-3 gap-5 mt-14")
                each propiedad in departamentos
                    include ./template/card.pug

        
                            
                             
block scripts
    script(src="https://unpkg.com/leaflet@1.8.0/dist/leaflet.js") 
    script(src="/js/mapaInicio.js") 



