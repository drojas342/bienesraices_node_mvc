extends ../layout/app

block styles  
    link(rel="stylesheet" href="https://unpkg.com/leaflet@1.8.0/dist/leaflet.css")
    


block contenido  

    

    div(class="py-5")
        h1(id="titulo" class="text-4xl my-10 font-extrabold text-center")= propiedad.titulo

        div 
            a(href="#" class="font-bold text-gray-600 text-sm") Categoria: 
                span(class="font-normal")= propiedad.categoria.nombre

        div(class="mt-5 md:flex md:gap-4 md:items-satart")
            div(class="md:w-2/3 bg-white shadow rounded-lg ")
                img(
                    src=`/uploads/${propiedad.imagen}`, 
                    alt=propiedad.titulo
                )

                div(class="px-5 py-10 space-y-5") 
                    p= propiedad.descripcion

                    h2(class="text-2xl leading-6 font-bold text-gray-900 ") Información Propiedad 

                    div(class="grid grid-cols-1 md:grid-cols-2 gap-4")
                        p(class="text-gray-600 font-bold text-xs")  WC 
                            span(class=" text-gray-800 ")= propiedad.wc  

                        p(class="text-gray-600 font-bold text-xs")  Habitaciones 
                            span(class=" text-gray-800 ")= propiedad.habitaciones  

                        p(class="text-gray-600 font-bold text-xs")  Estacionamientos 
                            span(class=" text-gray-800 ")= propiedad.estacionamientos

                        p(class="text-gray-600 font-bold text-xs")  Precio 
                            span(class=" text-gray-800 ")= propiedad.precio.nombre
                         

            aside(class="md:w-1/3 bg-white shadow rounded-lg")
                h3(class="text-center py-10 leading-6 font-bold text-gray-900") Ubicación 
                div(class="h-96" id="mapa")
                    p(id="lat" class="hidden")= propiedad.lat 
                    p(id="lng" class="hidden")= propiedad.lng 
                div(class="p-5")
                    p(class="text-gray-600 font-bold text-xs") Dirección 
                        span(id="calle" class="text-gray-900 block text-lg")= propiedad.calle
                    
                    if !vendedor

                        h3(class="text-2xl text-center my-10 font-extrabold rext-gray-900") Vendedor
                        if usuario

                            if errores 
                                div(class="max-w-md mx-auto my-10")
                                    each error in errores
                                        p(style="background-color:#dc2626; color:white; text-transform:uppercase; font-size:0.75rem; text-align:center; padding:0.5rem; margin-bottom:0.25rem; font-weight:bold")= error.msg

                            else if enviado
                                p(class="p-2 text-center bg-green-100 text-green-600 uppercase font-bold text-sm my-10") Mensaje enviado correctamente

                            form(method="POST") 
                                input(type="hidden" name="_csrf" value=csrfToken)
                                
                                div(class="space-y-5")
                                    label(for="mensaje") Mensaje
                                    textarea(
                                        id="mensaje" 
                                        name="mensaje" 
                                        placeholder="Escribe tu mensaje"
                                        class="w-full py-2 border px-2 border-gray-300 rounder-lg shadow placeholder-gray-400")
                                    
                                    input(type="submit" value="Enviar Mensaje" class="bg-indigo-600   text-white uppercase font-bold text-sm w-full p-2 cursor-pointer ")

                                        
                        else
                            div(class="flex justify-center gap-2")
                                p Si deseas contactar al vendedor 
                                    a(class="text-indigo-600" href="/auth/crear-cuenta") debes crear una cuenta
block scripts
    script(src="https://unpkg.com/leaflet@1.8.0/dist/leaflet.js")
    script(src="/js/mostrarMapa.js")



