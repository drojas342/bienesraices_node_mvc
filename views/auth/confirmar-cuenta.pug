extends ../layout/index

block contenido 
    .py-10
        h1.text-4xl.my-10.font-extrabold.text-center Bienes 
            span.font-normal Raices
        h2.text-center.text-2xl.font-extrabold= pagina

    div(class="bg-white shadow py-8 px-4 rounded-lg max-w-md mx-auto")

        p(class= error ? 'bg-red-500' : 'bg-green-500').py-2.px-5.rounded-lg.w-full.font-bold.text-center.text-.upp= mensaje

        if !error
            a(href="/auth/login" class="block text-center text-white bg-indigo-600 hover:bg-indigo-700 font-bold py-3 mt-5 rounded-lg") Iniciar Sesión
        else    
            a(href="/auth/registro" class="block text-center text-white bg-indigo-600 hover:bg-indigo-700 font-bold py-3 mt-5 rounded-lg") Crear Cuenta