extends ../layout/index

block contenido 
    .py-10
        a(href="/")
            h1.text-4xl.my-10.font-extrabold.text-center Bienes 
                span.font-normal Raices
        h2.text-center.text-2xl.font-extrabold= pagina

        if errores 
            div(class="max-w-md mx-auto my-10")
                each error in errores
                    p(style="background-color:#dc2626; color:white; text-transform:uppercase; font-size:0.75rem; text-align:center; padding:0.5rem; margin-bottom:0.25rem; font-weight:bold")= error.msg


        .mt-8.mx-auto.max-w-md
            .bg-white.py-8.px-4.shadow
                div.mb-6.rounded-lg.border.border-indigo-200.bg-indigo-50.p-4
                    p.text-sm.font-semibold.text-indigo-700.mb-2 Usuarios de prueba
                    p.text-sm.text-gray-600.mb-2 Para explorar el proyecto puedes iniciar sesión con cualquiera de estos usuarios:
                    ul.list-disc.list-inside.space-y-1.text-sm.text-gray-600
                        li
                            span.font-semibold diego@gmail.com
                            span.mx-1  — 
                            span password
                        li
                            span.font-semibold usuario1@gmail.com
                            span.mx-1  — 
                            span password
                        li
                            span.font-semibold usuario2@gmail.com
                            span.mx-1  — 
                            span password

                form.space-y-5(method="POST" action="/auth/login")
                    //- Aquí se incluye el token CSRF
                    input(type="hidden" name="_csrf" value=csrfToken)
                    div 
                        label.block.text-sm.uppercase.text-gray-500.mb-2.font-bold(for="email") Tu Email
                        input#email.w-full.px-3.py-2.border.border-gray-300.rounded.md.placeholder-gray-400(placeholder="Tu Email" type="email" name="email" )
                    div 
                        label.block.text-sm.uppercase.text-gray-500.mb-2.font-bold(for="password") Password
                        input#password.w-full.px-3.py-2.border.border-gray-300.rounded.md.placeholder-gray-400(placeholder="Tu password" type="Password" name="password" )

                    div.flex.items-center.justify-between
                        a.text-gray-500.text-xs(href="/auth/registro") ¿No tienes una cuenta? Crea una
                        a.text-gray-500.text-xs(href="/auth/olvide-password") Olvide mi Password
                    
                     
                    input(class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-3 cursor-pointer" type="submit" value="Iniciar Sesión")